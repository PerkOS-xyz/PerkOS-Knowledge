# PerkosClaimVault deploy (Foundry). Copy to .env and fill in.
#
# Two on-chain roles, on purpose (clean attribution for reports/stats):
#   OWNER       = governance — upgrade / pause / ownerWithdraw / set roles. Rare,
#                 sensitive. PerkOS: the platform wallet (a Safe is ideal).
#   DISTRIBUTOR = operator — posts the Merkle roots (setMerkleRoot) and funds the
#                 vault. Recurring on-chain activity attributes to THIS address.
# The DEPLOYER (pays gas) is separate from both — the owner is fixed in
# initialize, not by who deploys.

# --- OWNER (governance) ---
# PerkOS platform wallet. MUST be a Safe/timelock ideally (an EOA works for v1).
SAFE_OWNER=0xc2564e41B7F5Cb66d2d99466450CfebcE9e8228f

# --- DISTRIBUTOR (operator) ---
# Posts roots + funds the vault. PerkOS: the treasury wallet. Leave as the zero
# address for owner-only. NOTE: whoever posts roots can authorize claims, so this
# key is fund-sensitive — owner can pause + rotate it as the backstop.
DISTRIBUTOR_ADDRESS=0x3f0D7b9916212fA0A9Ac0EF8f72a25EB56F7046C

# --- DEPLOYER (pays gas; does NOT become owner) ---
DEPLOYER_PRIVATE_KEY=

# --- Tokens, per network (deploy.sh picks by network arg) ---
# Base mainnet:
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PERKOS_ADDRESS=0xF714E60f85497D70508F7E356b5DB80e64539BA3
# Celo mainnet (./deploy.sh celo):
USDC_ADDRESS_CELO=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
PERKOS_ADDRESS_CELO=0xb7Ba43fBD4F2E85FCE929f7d4DFE3905Ae846A46
# $PERKOS is OPTIONAL at deploy — leave a PERKOS_* blank to deploy USDC-only and
# wire it later with setRewardToken (USDC claims work regardless).

# Optional — Etherscan v2 key enables source verification on deploy (Base + Celo).
ETHERSCAN_API_KEY=

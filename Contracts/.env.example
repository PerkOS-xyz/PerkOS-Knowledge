# PerkosClaimVault deploy (Foundry). Copy to .env and fill in.

# Proxy owner — MUST be a Gnosis Safe / timelock, NOT an EOA. Gets
# root-setting + ownerWithdraw + upgrade authorization.
SAFE_OWNER=0x0000000000000000000000000000000000000000

# Deployer wallet (pays gas; does NOT become owner). A burner is fine.
DEPLOYER_PRIVATE_KEY=

# Token addresses on the target chain.
# Base mainnet USDC:
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# $PERKOS — OPTIONAL at deploy (it's bought later by the buyback). Leave blank
# to deploy USDC-only; wire it later with setRewardToken. USDC claims work now.
PERKOS_ADDRESS=

# Hot key allowed to POST Merkle roots (the off-chain claim service). Leave as
# the zero address for owner-only (the Safe posts roots). If set, this key can
# authorize claims — treat it as fund-sensitive (pause + ownerWithdraw backstop).
DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — Etherscan v2 key enables source verification on deploy.
ETHERSCAN_API_KEY=

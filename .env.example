# PerkOS Knowledge — app config. Copy to .env and fill in.
# In production these live in /opt/perkos-knowledge/.env (passed to the app
# container via docker-compose env_file). Secrets never go in git.
#
# NOTE: the tunable economics (per-tier prices, the fee waterfall, reward split,
# buyback flag) are NOT env anymore — they're admin-editable in the DB
# (tokenomics_config, via /admin/billing → Tokenomics). The vars below are
# infra: storage, embeddings, the payment token/treasury, and the claim vault.

# --- Postgres ---
POSTGRES_HOST=perkos-knowledge-postgres
POSTGRES_PORT=5432
POSTGRES_DB=perkos_knowledge
POSTGRES_USER=perkos_knowledge
POSTGRES_PASSWORD=

# --- Qdrant (vector search) ---
QDRANT_URL=http://perkos-knowledge-qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_items

# --- Embeddings (self-hosted PerkOS-LLM gateway; all-minilm 384-dim) ---
KNOWLEDGE_EMBEDDING_PROVIDER=openai            # openai-compatible API shape
KNOWLEDGE_EMBEDDING_BASE_URL=https://api.llm.perkos.xyz/v1
KNOWLEDGE_EMBEDDING_MODEL=all-minilm
KNOWLEDGE_EMBEDDING_API_KEY=allowlisted-vps-temporary
KNOWLEDGE_HYBRID=1                             # BM25 + vector RRF fusion

# --- Access / admin ---
KNOWLEDGE_ALLOWED_WALLET=                      # the platform wallet (also admin via x-admin-wallet)
KNOWLEDGE_ADMIN_TOKEN=                         # optional bearer alternative to x-admin-wallet
KNOWLEDGE_INGEST_TOKEN=                        # provider ingest bearer
KNOWLEDGE_EXEMPT_WALLETS=                      # comma list — query free (platform / research agents)
KNOWLEDGE_REQUIRE_EVIDENCE=1
KNOWLEDGE_DEFAULT_QUALITY_MODE=standard

# --- Payment rail (x402) — infra only; prices live in tokenomics_config ---
KNOWLEDGE_X402_MODE=credit                     # metered_free | enforce | credit (DB can override)
KNOWLEDGE_X402_CURRENCY=USDC
KNOWLEDGE_X402_CHAIN=base
KNOWLEDGE_X402_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913   # Base USDC
KNOWLEDGE_X402_PAY_TO=                         # treasury address (deposits land here)
KNOWLEDGE_X402_EXPOSE_SETTLEMENT=false
# Optional facilitator (enforce mode only):
KNOWLEDGE_X402_FACILITATOR_URL=
KNOWLEDGE_X402_FACILITATOR_VERIFY_PATH=/verify
KNOWLEDGE_X402_REQUIRE_FACILITATOR=true
KNOWLEDGE_X402_VERIFY_TIMEOUT_MS=8000

# --- Treasury / settlement / claim vault (on-chain payouts + $PERKOS reward) ---
KNOWLEDGE_TREASURY_ADDRESS=                    # treasury (pay-to + settlement source)
KNOWLEDGE_TREASURY_PRIVATE_KEY=               # SERVER SECRET — gates on-chain settlement + buyback (leave unset = record-only)
KNOWLEDGE_BASE_RPC_URL=https://mainnet.base.org
KNOWLEDGE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
KNOWLEDGE_USDC_DECIMALS=6
# PerkosClaimVault (contracts/) — set after deploy:
KNOWLEDGE_CLAIM_VAULT_ADDRESS=
KNOWLEDGE_PERKOS_TOKEN_ADDRESS=

# --- Site / wallet ---
NEXT_PUBLIC_SITE_URL=https://knowledge.perkos.xyz
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
